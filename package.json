{
	"name": "@kwit/sdk",
	"version": "0.1.3",
	"description": "Official TypeScript SDK for the Kwit billing API",
	"type": "module",
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"repository": {
		"type": "git",
		"url": "https://github.com/siebenberge/sdk"
	},
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.js"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		},
		"./zahls": {
			"import": {
				"types": "./dist/zahls/index.d.ts",
				"default": "./dist/zahls/index.js"
			},
			"require": {
				"types": "./dist/zahls/index.d.cts",
				"default": "./dist/zahls/index.cjs"
			}
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch"
	},
	"peerDependencies": {
		"typescript": "^5"
	},
	"dependencies": {
		"axios": "^1.13.4",
		"crypto-js": "^4.2.0",
		"qs": "^6.15.0"
	},
	"devDependencies": {
		"@types/crypto-js": "^4.2.2",
		"tsup": "^8.4.0"
	},
	"keywords": [
		"kwit",
		"billing",
		"subscription",
		"payments",
		"sdk",
		"typescript"
	],
	"license": "MIT",
	"engines": {
		"node": ">=22"
	}
}